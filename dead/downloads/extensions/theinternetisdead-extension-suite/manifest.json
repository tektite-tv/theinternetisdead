{
  "manifest_version": 3,
  "name": "theinternetisdead-extension-suite",
  "version": "1.56.36",
  "description": "A stable theinternetisdead extension suite with customizer, favorites, reader, storage reader, and per-tab media volume controls.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "bookmarks",
    "tabs",
    "downloads"
  ],
  "action": {
    "default_title": "theinternetisdead-extension-suite",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-customizer.js",
        "content-reader.js",
        "content-volume.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/black-and-white-grid.png",
        "assets/cobblestone.png",
        "assets/cracked-01.png",
        "assets/cracked-02.png",
        "assets/dirt.png",
        "assets/grass.png",
        "assets/lime-and-magenta-grid.png",
        "assets/sand.png",
        "assets/tv-wood.png",
        "assets/water.png",
        "stored-themes/index.json",
        "stored-themes/*.json",
        "stored-themes/ChatGPT/index.json",
        "stored-themes/ChatGPT/*.json",
        "stored-themes/YouTube/index.json",
        "stored-themes/YouTube/*.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
